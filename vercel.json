{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/upload.js": { "maxDuration": 60 },
    "api/admin.js": { "maxDuration": 30 },
    "api/auth.js": { "maxDuration": 10 }
  }
}