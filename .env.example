# ── Copy this file to .env and fill in your values ──────────
# Never commit .env to git — it's in .gitignore already

# Your Supabase project URL
# Found at: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Supabase anon/public key — safe to use in frontend
# Found at: Supabase Dashboard → Settings → API → anon public
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Admin dashboard only (.env in admin-dashboard/ folder) ──
# Service role key — NEVER put this in the main frontend app
# Found at: Supabase Dashboard → Settings → API → service_role
VITE_SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
